{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "registry_defaults", "selection_policy", "skill_templates", "skills"],
  "properties": {
    "version": { "type": "string" },
    "registry_defaults": { "type": "object", "additionalProperties": true },
    "selection_policy": { "type": "object", "additionalProperties": true },
    "skill_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill_id", "source", "enabled"],
        "properties": {
          "skill_id": { "type": "string" },
          "source": { "type": "string" },
          "enabled": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "skills": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
  },
  "additionalProperties": true
}
