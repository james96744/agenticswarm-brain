{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "registry_defaults", "selection_policy", "cli_templates", "cli_entries"],
  "properties": {
    "version": { "type": "string" },
    "registry_defaults": { "type": "object", "additionalProperties": true },
    "selection_policy": { "type": "object", "additionalProperties": true },
    "cli_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cli_id", "enabled", "source", "category", "command"],
        "properties": {
          "cli_id": { "type": "string" },
          "enabled": { "type": "boolean" },
          "source": { "type": "string" },
          "category": { "type": "string" },
          "command": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "cli_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cli_id", "enabled", "source", "scope", "command"],
        "properties": {
          "cli_id": { "type": "string" },
          "enabled": { "type": "boolean" },
          "source": { "type": "string" },
          "scope": { "type": "string" },
          "command": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
